DATABASE_URL="mysql://root:root@localhost:3306/Msec_App_RT"
JWT_SECRET="changez-moi-en-production-minimum-32-caracteres"
JWT_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN="http://localhost:5173"
MAX_FILE_SIZE_MB=10
PUBLIC_BASE_URL="http://localhost:4000"

# Web Push (VAPID) — optionnel ; sans ces clés, l’API renvoie publicKey: null et n’envoie pas de push
# Génération : npx web-push generate-vapid-keys
# VAPID_SUBJECT doit être un mailto: ou une URL https:
# VAPID_PUBLIC_KEY="..."
# VAPID_PRIVATE_KEY="..."
# VAPID_SUBJECT="mailto:contact@example.com"
